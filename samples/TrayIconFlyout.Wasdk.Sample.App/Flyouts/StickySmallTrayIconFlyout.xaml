<local:TrayIconFlyout
	x:Class="U5BFA.Libraries.StickySmallTrayIconFlyout"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:U5BFA.Libraries"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	FlyoutWidth="360"
	mc:Ignorable="d">

	<local:TrayIconFlyoutIsland IslandHeight="260">
		<Grid Padding="18" RowSpacing="14">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<StackPanel Spacing="4">
				<TextBlock
					FontFamily="Segoe UI Variable Display"
					FontSize="20"
					FontWeight="SemiBold"
					Text="Compact flyout" />
				<TextBlock
					Opacity="0.72"
					Text="Single island layout"
					TextWrapping="Wrap" />
			</StackPanel>

			<StackPanel
				Grid.Row="1"
				VerticalAlignment="Center"
				Spacing="8">
				<ToggleSwitch Header="Sync status" IsOn="True" />
				<ProgressBar Value="64" />
			</StackPanel>

			<Button
				Grid.Row="2"
				HorizontalAlignment="Right"
				Content="Done" />
		</Grid>
	</local:TrayIconFlyoutIsland>

</local:TrayIconFlyout>
