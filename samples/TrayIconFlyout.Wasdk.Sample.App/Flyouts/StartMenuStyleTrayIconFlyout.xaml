<local:TrayIconFlyout
	x:Class="U5BFA.Libraries.StartMenuStyleTrayIconFlyout"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:U5BFA.Libraries"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	FlyoutWidth="360"
	IslandsOrientation="Horizontal"
	mc:Ignorable="d">

	<local:TrayIconFlyoutIsland
		Height="220"
		IslandWidth="140">
		<Grid Padding="16">
			<StackPanel VerticalAlignment="Center" Spacing="8">
				<TextBlock
					FontFamily="Segoe UI Variable Display"
					FontSize="18"
					FontWeight="SemiBold"
					Text="Now" />
				<TextBlock
					Opacity="0.72"
					Text="Horizontal island"
					TextWrapping="Wrap" />
				<Button Content="Open" />
			</StackPanel>
		</Grid>
	</local:TrayIconFlyoutIsland>

	<local:TrayIconFlyoutIsland
		Height="220"
		IslandWidth="*">
		<Grid Padding="16" RowSpacing="12">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<TextBlock
				FontFamily="Segoe UI Variable Display"
				FontSize="18"
				FontWeight="SemiBold"
				Text="Details" />

			<ListView Grid.Row="1" SelectionMode="None">
				<ListViewItem Content="IslandWidth=*" />
				<ListViewItem Content="Stretch content" />
				<ListViewItem Content="Shared settings" />
			</ListView>

			<Slider
				Grid.Row="2"
				Maximum="100"
				Value="42" />
		</Grid>
	</local:TrayIconFlyoutIsland>

</local:TrayIconFlyout>
